{
  "appId": "cl.triflow.app",
  "appName": "TriFlow",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1A1A1A",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1A1A1A"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "Camera": {
      "presentationStyle": "fullscreen"
    }
  }
}
